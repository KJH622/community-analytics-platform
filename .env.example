POSTGRES_DB=market_signal_hub
POSTGRES_USER=market
POSTGRES_PASSWORD=market
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://market:market@db:5432/market_signal_hub
ASYNC_DATABASE_URL=postgresql+asyncpg://market:market@db:5432/market_signal_hub
API_HOST=0.0.0.0
API_PORT=8000
APP_ENV=development
APP_DEBUG=true
APP_NAME=market-signal-hub
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Asia/Seoul
BLS_API_URL=https://api.bls.gov/publicAPI/v2/timeseries/data/
FRED_SERIES_BASE_URL=https://fred.stlouisfed.org/graph/fredgraph.csv
NASDAQ_MARKETS_RSS=https://www.nasdaq.com/feed/rssoutbound?category=Markets
NASDAQ_STOCKS_RSS=https://www.nasdaq.com/feed/rssoutbound?category=Stocks
REQUEST_TIMEOUT_SECONDS=20
HTTP_USER_AGENT=market-signal-hub/0.1 (+https://example.local)
COMMUNITY_CONNECTORS_ENABLED=false
MOCK_COMMUNITY_CONNECTOR_ENABLED=true
SCHEDULER_ENABLED=true
FRONTEND_API_BASE_URL=http://localhost:8000
